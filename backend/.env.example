# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/spotify-clone
# OR use MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/spotify-clone

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRE=30d

# Cloudinary (for song/image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (first admin account)
ADMIN_EMAIL=admin@spotify-clone.com
ADMIN_PASSWORD=Admin@123

# Last.fm API (for fetching new songs metadata - free)
LASTFM_API_KEY=your_lastfm_api_key
